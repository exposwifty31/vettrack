index 00000000..9c0d8e11
--- /dev/null
+++ b/server/services/equipment-readiness-rules.service.ts
@@ -0,0 +1,31 @@
+import { eq } from "drizzle-orm";
+import { db, serverConfig } from "../db.js";
+import {
+  parseEquipmentReadinessRulesV1,
+  type EquipmentReadinessRulesV1,
+} from "../../shared/equipment-readiness-rules.js";
+
+/** Per-clinic key in `vt_server_config` (no global clinic semantics). */
+export const READINESS_RULES_CONFIG_KEY = (clinicId: string) =>
+  `equipment.readinessRules.v1:${clinicId}`;
+
+const rulesCache = new Map<string, { rules: EquipmentReadinessRulesV1; loadedAt: number }>();
+const CACHE_TTL_MS = 60_000;
+
+export async function getReadinessRules(clinicId: string): Promise<EquipmentReadinessRulesV1> {
+  const cached = rulesCache.get(clinicId);
+  if (cached && Date.now() - cached.loadedAt < CACHE_TTL_MS) {
+    return cached.rules;
+  }
+
+  const key = READINESS_RULES_CONFIG_KEY(clinicId);
+  const [row] = await db
+    .select({ value: serverConfig.value })
+    .from(serverConfig)
+    .where(eq(serverConfig.key, key))
+    .limit(1);
+
+  const rules = parseEquipmentReadinessRulesV1(row?.value ?? null);
+  rulesCache.set(clinicId, { rules, loadedAt: Date.now() });
+  return rules;
+}
