+### D.8 `matchesRouteFamily` (required helper)
+
+```ts
+export function matchesRouteFamily(
+  pathname: string,
+  routes: readonly string[],
+): boolean {
+  return routes.some((route) => {
+    if (pathname === route) return true;
+    return pathname.startsWith(`${route}/`);
+  });
+}
+```
