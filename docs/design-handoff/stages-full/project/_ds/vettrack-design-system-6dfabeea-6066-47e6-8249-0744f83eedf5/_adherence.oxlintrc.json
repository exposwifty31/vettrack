    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|tone|key|ref|className|style|children)$/]",
        "message": "<AlertCard> doesn't accept that prop. Declared props: icon, title, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:err|warn|ok)$/]",
        "message": "<AlertCard> tone must be one of 'err' | 'warn' | 'ok'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AlertsDropdown'] > JSXAttribute > JSXIdentifier[name!=/^(?:alerts|alertCount|badgeAnimating|key|ref|className|style|children)$/]",
        "message": "<AlertsDropdown> doesn't accept that prop. Declared props: alerts, alertCount, badgeAnimating."
