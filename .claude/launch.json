{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API Server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:api"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "Web (Vite)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:web"],
      "port": 5000,
      "autoPort": false
    },
    {
      "name": "Full Dev (API + Web)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 5000
    },
    {
      "name": "Worker",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["worker"],
      "port": null
    }
  ]
}
