{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    // TODO(arch): enable both flags and add knip to CI once the dead-code sweep (fix 13-15) is complete.
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "*": ["./*"]
    }
  },
  "include": ["server/**/*.ts", "shared/**/*.ts", "shared-contracts/**/*.ts", "lib/**/*.ts"],
  "exclude": ["server/tests/**", "node_modules"]
}
