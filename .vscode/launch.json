{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "API: server/index.ts",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "tsx", "server/index.ts"],
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "3001",
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Worker: notification.worker",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "tsx", "server/workers/notification.worker.ts"],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach: Node (port 9229)",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Web: Vite :5000",
      "url": "http://localhost:5000",
      "webRoot": "${workspaceFolder}/src"
    }
  ],
  "compounds": [
    {
      "name": "Full stack (API + Chrome)",
      "configurations": ["API: server/index.ts", "Web: Vite :5000"],
      "stopAll": true
    }
  ]
}
