# =============================================================================
# VetTrack Environment Variables
# Copy this file to .env (or .env.local) and fill in values before running.
# Variables marked [REQUIRED] must be set in production.
# Variables marked [OPTIONAL] have defaults or are only needed for specific features.
#
# Minimal local dev (no Clerk): DATABASE_URL, SESSION_SECRET, NODE_ENV=development
# only — see docs/pilot.md "Pilot readiness runbook" and AGENTS.md.
# =============================================================================

# =============================================================================
# Production startup gate (`pnpm start` — NODE_ENV=production)
# =============================================================================
# server/lib/envValidation.ts (REQUIRED_IN_PRODUCTION + PostgreSQL) requires every
# variable below to be non-empty for a green production boot. Dev workflows
# (`pnpm dev`, `pnpm start:local`) run with NODE_ENV=development and skip this gate,
# so you can mock or omit secrets locally while iterating.
#
#   • DATABASE_URL or POSTGRES_URL (PostgreSQL)
#   • REDIS_URL
#   • SESSION_SECRET
#   • CLERK_SECRET_KEY
#   • VITE_CLERK_PUBLISHABLE_KEY
#   • ALLOWED_ORIGIN
#   • DB_CONFIG_ENCRYPTION_KEY  (needed to decrypt vt_server_config rows;
#                                missing key → integration credentials
#                                silently return null and every integration
#                                sync/validation path fails as "not configured")
#
#   • CLERK_WEBHOOK_SECRET      (Clerk user/org lifecycle webhooks; 501 if unset)
#   • DATA_INTEGRITY_HEALTH_TOKEN (required for /api/health/data-integrity probe)
# =============================================================================

# --- Database ---

# [REQUIRED] PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Example: postgres://vettrack:strongpassword@db.example.com:5432/vettrack
DATABASE_URL=postgres://user:password@localhost:5432/vettrack
# Optional alias (if set, takes precedence over DATABASE_URL)
# POSTGRES_URL=

# --- Redis (task dashboard cache + BullMQ notification / automation queue) ---

# Without Redis: API and app run, but queues, web-push fan-out, task dashboard cache, and automation
# ticks are disabled (see QUEUE_DISABLED_NO_REDIS / REDIS_DISABLED logs). Production MUST set REDIS_URL
# for full functionality and MUST run the worker as a separate process (pnpm run worker:notifications).
#
# Local dev (Docker): docker run -p 6379:6379 redis
REDIS_URL=redis://localhost:6379

# Production example (managed): redis://default:password@host:6379
# REDIS_URL=
#
# Optional reliability tuning (defaults shown)
# REDIS_CONNECT_TIMEOUT_MS=5000
# REDIS_COMMAND_TIMEOUT_MS=4000
# REDIS_MAX_RETRIES_PER_REQUEST=1

# --- Task automation engine (BullMQ worker + Redis) ---

# When true, worker runs automation rules: overdue escalation, auto-assign, stuck notify, pre-start reminders.
ENABLE_AUTOMATION_ENGINE=false

# [OPTIONAL] When "true", registers the stale clinical check-in sweep cron on the unified job runtime
# (stale-checkin-sweep queue). Default: unset/false — worker skipped, readiness still ok.
# STALE_CHECKIN_SWEEP_ENABLED=true

# --- Session Security ---

# [REQUIRED] A long, random secret used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: Never use the default value in production.
SESSION_SECRET=REPLACE_ME_generate_with__node_-e__console.log(require('crypto').randomBytes(64).toString('base64'))

# [REQUIRED in production] 32-byte hex key for encrypting sensitive vt_server_config values
# (integration credentials, SMTP password, webhook secrets).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In dev (NODE_ENV !== production) it may be omitted — values fall through as plaintext.
DB_CONFIG_ENCRYPTION_KEY=REPLACE_ME_generate_with_node_-e_require_crypto_randomBytes_32_toString_hex

# --- Clerk Authentication ---

# [OPTIONAL for local dev] Omit CLERK_SECRET_KEY and VITE_CLERK_PUBLISHABLE_KEY with
# NODE_ENV=development to use dev-bypass auth (hardcoded admin user). Production requires both keys.
#
# [OPTIONAL] Set to "false" to disable Clerk middleware even when CLERK_SECRET_KEY is set.
# CLERK_ENABLED=false

# [REQUIRED in production] Clerk secret key (server-side). Starts with sk_live_ or sk_test_.
# Find in Clerk Dashboard > API Keys.
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# [REQUIRED] Clerk publishable key (used by the Vite frontend). Starts with pk_live_ or pk_test_.
# Must be prefixed with VITE_ so Vite exposes it to the browser bundle.
# Find in Clerk Dashboard > API Keys.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# [REQUIRED for bundled Capacitor shell] Production API origin baked at build time.
# Native archives: ./scripts/build-native-shell.sh reads this from .env only (.env.local ignored).
# Example: https://vettrack.uk
VITE_API_ORIGIN=https://vettrack.uk

# [REQUIRED for production] Webhook signing secret for Clerk user/org lifecycle sync.
# Clerk Dashboard > Webhooks > Endpoint > Signing Secret (starts with whsec_).
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# --- VAPID Keys (Web Push Notifications) ---

# [OPTIONAL] VAPID public key for web push. If not set, keys are auto-generated
# and stored in the database on first startup.
# Generate a fresh pair: npx web-push generate-vapid-keys
# Example public key (replace with your own; public key is safe to expose to the client):
VAPID_PUBLIC_KEY=BLboFm_5c43dhi8x4C6qVoF44qjF2lGhGoWM125s-Ue8BuJ3HI3qvuM8bi6HvtLSPsZfjMRCjUU4BdKZnNLSkEQ

# [OPTIONAL] VAPID private key for web push. Must be paired with VAPID_PUBLIC_KEY.
# Paste the "Private Key" from the same `npx web-push generate-vapid-keys` run into your local .env only — never commit real secrets.
VAPID_PRIVATE_KEY=

# [OPTIONAL] Client-exposed VAPID public key for push subscriptions.
# Must match VAPID_PUBLIC_KEY.
VITE_VAPID_PUBLIC_KEY=BLboFm_5c43dhi8x4C6qVoF44qjF2lGhGoWM125s-Ue8BuJ3HI3qvuM8bi6HvtLSPsZfjMRCjUU4BdKZnNLSkEQ

# --- Admin Access ---

# [OPTIONAL] Comma-separated list of email addresses that are automatically
# granted admin role when they sign in via Clerk.
# Example: admin@example.com,ops@example.com
ADMIN_EMAILS=your-email@example.com

# --- ER Pilot mode ---

# [OPTIONAL] Equipment-only pilot mode (dedicated deploys only — NOT mainline production).
# Requires ALLOW_EQUIPMENT_PILOT_MODE=true on the host/build, then set both below and rebuild.
# Frontend: hides non-equipment routes; backend: skips full-platform API modules.
# Mainline Railway/Docker builds force VITE_PILOT_MODE=false; runtime blocks PILOT_MODE=true
# in production unless ALLOW_EQUIPMENT_PILOT_MODE=true.
# ALLOW_EQUIPMENT_PILOT_MODE=true
# VITE_PILOT_MODE=true
# PILOT_MODE=true

# --- Phase 2.2 service-task domain (optional) ---

# [OPTIONAL] When true, enables service-task adapter + audit logging for users in the rollout cohort.
# Deploy with false; enable in staging/production gradually. Rollback: set false and SERVICE_TASK_MODE_PERCENT=0.
# ENABLE_SERVICE_TASK_MODE=false

# [OPTIONAL] 0–100. Percentage of users (deterministic by user id) that receive service-task mode when ENABLE_SERVICE_TASK_MODE=true.
# SERVICE_TASK_MODE_PERCENT=0

# [OPTIONAL] When not false, if Clerk session has no org id (or session org does not match DB),
# clinic is resolved from the existing vt_users row. Set to false if every session must carry a Clerk org id.
# Alias: ALLOW_DB_CLINIC_FALLBACK (same semantics; either may be set to false to disable).
# DB_CLINIC_FALLBACK=true
#
# [OPTIONAL] Set to 1 or true to log structured AUTH_DEBUG lines for resolveAuthUser / pending gate (do not enable in prod long-term).
# AUTH_DEBUG=

# --- Phase 2.5 clinical check-in authority (optional, request-time gated) ---

# [OPTIONAL] When "true", server/lib/authority.ts resolves clinical authority
# from the vt_clinical_check_ins table when an open row exists for the user,
# instead of from vt_shifts. Strategy A is preserved: when no open check-in
# row exists (or this flag is unset/false), snapshots are byte-for-byte
# identical to the legacy shift-only resolution. The flag is read on every
# call to resolveAuthority(), so toggling it off rolls back in production
# without a redeploy. Roll out per environment: dev → staging → one clinic →
# wider. Observe adoption via the dispense_confirmed audit metadata fields
# authoritySource / authorityReason / authorityOperationalRole.
# AUTHORITY_USE_CHECKIN_PATH=false

# --- Server ---

# [OPTIONAL] Port the API server listens on. Defaults to 3001.
PORT=3001

# [OPTIONAL] Node environment. Set to "production" for production deployments.
NODE_ENV=development

# [OPTIONAL] When true/1, shortens scheduler intervals and treats "expected return minutes"
# as seconds for local testing. Leave unset or false in production and demos.
# TEST_MODE=false

# --- CORS ---

# [REQUIRED for production] Allowed browser origin for CORS (must match the site URL, no trailing slash).
# Mandatory for `pnpm start`; optional for local dev when using default dev CORS behavior.
# Example: https://vettrack.uk
ALLOWED_ORIGIN=https://vettrack.uk

# --- Sentry Error Tracking ---

# [OPTIONAL] Sentry DSN for server-side error reporting. Leave blank to disable.
# Find in Sentry Dashboard > Project Settings > Client Keys (DSN).
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# [OPTIONAL] Sentry DSN for frontend (browser) error reporting.
# Must be prefixed with VITE_ so Vite exposes it to the browser bundle.
# Can be the same DSN as SENTRY_DSN, or a separate Sentry project.
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- SMTP (Pharmacy Forecast email delivery) ---

# The pharmacy forecast "Approve & Send" flow uses these to deliver the weekly
# order email to the clinic pharmacy. If ANY of SMTP_HOST / SMTP_USER / SMTP_PASS
# is missing, the server falls back to a `mailto:` URL returned to the browser
# (opens the user's mail client with the body pre-filled — user must click Send).
#
# [OPTIONAL] SMTP server hostname. Gmail: smtp.gmail.com
SMTP_HOST=smtp.gmail.com
#
# [OPTIONAL] SMTP port. 587 = STARTTLS (recommended), 465 = implicit TLS.
SMTP_PORT=587
#
# [OPTIONAL] Use implicit TLS. Set to "true" ONLY when using port 465. For 587 leave false.
SMTP_SECURE=false
#
# [OPTIONAL] SMTP username. For Gmail this is your full address, e.g. you@gmail.com
SMTP_USER=
#
# [OPTIONAL] SMTP password. For Gmail you MUST use a 16-char App Password
# (not your regular account password). Generate one at:
#   https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your Google account.
SMTP_PASS=
#
# [OPTIONAL] "From:" address shown to the pharmacy recipient. Defaults to SMTP_USER.
# Example: clinic-orders@yourclinic.com
SMTP_FROM=
#
# [OPTIONAL] Forecast delivery policy flags:
# - In production, fallback to mailto is disabled by default (SMTP-only).
# - Set FORECAST_ALLOW_MAILTO_FALLBACK=true to re-enable legacy fallback behavior.
# - Set FORECAST_SMTP_REQUIRED=true to force SMTP-only in any environment.
# FORECAST_ALLOW_MAILTO_FALLBACK=false
# FORECAST_SMTP_REQUIRED=false

# --- WhatsApp Alerts ---

# [OPTIONAL] Default WhatsApp number for equipment alerts (E.164 format).
# Example: +15550001234
WHATSAPP_DEFAULT_PHONE=

# --- Data integrity health probe (production-required) ---

# [REQUIRED in production] Bearer for GET /api/health/data-integrity (tenant-isolation counts).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Callers must send header: x-health-token: <value>
# DATA_INTEGRITY_HEALTH_TOKEN=

# --- System health (outbox / realtime pipeline) ---

# [OPTIONAL] Background monitor interval (ms). Default: 300000 (5 minutes).
# SYSTEM_HEALTH_MONITOR_INTERVAL_MS=300000
#
# Publish lag tiers (ms): WARNING > 2000 default; CRITICAL > 5000 default.
# SYSTEM_HEALTH_PUBLISH_LAG_MS_WARNING=2000
# SYSTEM_HEALTH_PUBLISH_LAG_MS_CRITICAL=5000
#
# Gap resync spike (global counter delta per tick): INFO ≥ threshold 1; WARNING ≥ threshold 5 (defaults).
# SYSTEM_HEALTH_GAP_RESYNC_DELTA_INFO=1
# SYSTEM_HEALTH_GAP_RESYNC_DELTA_WARNING=5
#
# [OPTIONAL] Critical when cumulative outbox_failed_publish_attempts increases by at least this
# amount between monitor ticks (same window as SYSTEM_HEALTH_MONITOR_INTERVAL_MS). Default: 10.
# SYSTEM_HEALTH_FAILED_PUBLISH_DELTA_CRITICAL=10
#
# [OPTIONAL] Dedupe window for CRITICAL urgent webhooks only (ms). Redis SET NX when REDIS_URL is set,
# else in-memory. INFO/WARNING are never webhook-deduped. Default: 900000 (15 minutes).
# SYSTEM_HEALTH_WEBHOOK_DEDUPE_MS=900000
#
# [OPTIONAL] Persistent JSONL log path for all severity tiers (console also). Default: logs/system-health-alerts.log
# SYSTEM_HEALTH_ALERT_LOG_PATH=
#
# [OPTIONAL] Public app base URL for Ops Dashboard links in CRITICAL alerts (falls back to first ALLOWED_ORIGIN).
# SYSTEM_HEALTH_APP_BASE_URL=https://app.example.com
# PUBLIC_APP_URL=
#
# Routing: INFO/WARNING → console + alert log + optional standard webhook.
# SYSTEM_ALERT_STANDARD_WEBHOOK_URL=
#
# CRITICAL → console + alert log + urgent webhook (PagerDuty / urgent Slack incoming webhook).
# If unset, falls back to legacy Slack + Discord below.
# SYSTEM_ALERT_CRITICAL_WEBHOOK_URL=
#
# [OPTIONAL] Legacy defaults when SYSTEM_ALERT_CRITICAL_WEBHOOK_URL is not set (CRITICAL tier only).
# SYSTEM_ALERT_SLACK_WEBHOOK_URL=
# SYSTEM_ALERT_DISCORD_WEBHOOK_URL=
# Fallback aliases if you prefer generic names:
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=

# --- Asset Copilot (Claude / Anthropic — optional) ---

# [OPTIONAL] Enable Asset Copilot HTTP routes (default off). Requires DATABASE_URL + equipment data.
# ENABLE_ASSET_COPILOT=false

# [OPTIONAL] Anthropic API key for Claude narration (server-only — never prefix with VITE_).
# Get from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-...

# [OPTIONAL] When true and ANTHROPIC_API_KEY is set, explain responses use Claude for prose.
# Resolver claims/citations are always evidence-backed; LLM only narrates validated claims.
# ASSET_COPILOT_LLM_ENABLED=false

# [OPTIONAL] Provider gate (only "anthropic" is supported today).
# ASSET_COPILOT_LLM_PROVIDER=anthropic

# [OPTIONAL] Claude model id for copilot narration.
# ASSET_COPILOT_LLM_MODEL=claude-sonnet-4-20250514

# --- Cursor Cloud Agents (intelligent bug fixer — optional) ---

# [OPTIONAL] Enable admin API + UI to dispatch Cursor Cloud Agents on support tickets.
# ENABLE_CURSOR_BUG_FIXER=false

# [OPTIONAL] Cursor Cloud Agents API key (Dashboard → Cloud Agents → My Settings → API Keys).
# Use Basic auth; never expose to the browser (no VITE_ prefix).
# CURSOR_API_KEY=

# [OPTIONAL] GitHub repository URL for the agent to clone (required when enabled).
# Cursor Cloud Agents require GitHub — use a mirror if primary hosting is GitLab.
# CURSOR_BUG_FIXER_REPO_URL=https://github.com/your-org/vettrack

# [OPTIONAL] Default branch/ref for new fix branches.
# CURSOR_BUG_FIXER_DEFAULT_REF=main

# [OPTIONAL] Open a PR when the agent finishes (default true).
# CURSOR_BUG_FIXER_AUTO_CREATE_PR=true

# [OPTIONAL] Explicit model id from GET https://api.cursor.com/v1/models (omit for account default).
# CURSOR_BUG_FIXER_MODEL=

# --- Realtime (SSE — canonical; do not use WebSockets for ward/ER) ---

# Live updates use Server-Sent Events: GET /api/realtime/stream (outbox-backed).
# Reconnect replay: GET /api/realtime/replay. Emergency reads bypass the service worker cache
# (see shared/emergency-surfaces.manifest.ts). VITE_WS_URL is legacy and unused by mainline UI.
# Do not set VITE_WS_URL for new deployments.

# --- Replit Dev Environment (auto-set by Replit, do not set manually) ---

# [OPTIONAL] Replit dev domain — used to configure CORS in development.
# Automatically set by Replit. You do not need to set this.
# REPLIT_DEV_DOMAIN=

# --- Staging E2E only (never production) ---

# Required to run pnpm staging:seed / staging:cleanup (scripts/staging/guard.ts).
# STAGING_E2E_CONFIRM=yes
# Shared password for temporary Clerk users (min 12 chars; do not commit).
# STAGING_E2E_PASSWORD=
# Optional clinic id for staging personas (default dev-clinic-default).
# STAGING_E2E_CLINIC_ID=dev-clinic-default
# Playwright: auto-run pnpm staging:cleanup after test:staging:e2e.
# STAGING_E2E_AUTO_CLEANUP=yes
